{
  "name": "@model-bridge/sdk",
  "version": "1.0.0",
  "description": "Production-grade TypeScript SDK for ModelBridge AI Gateway",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/modelbridge/sdk-typescript.git"
  },
  "bugs": {
    "url": "https://github.com/modelbridge/sdk-typescript/issues"
  },
  "homepage": "https://github.com/modelbridge/sdk-typescript#readme",
  "keywords": [
    "modelbridge",
    "ai",
    "sdk",
    "typescript",
    "api",
    "gateway",
    "chat",
    "completion"
  ],
  "author": "ModelBridge Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepublish": "npm run build",
    "prepublishOnly": "npm run build && npm run test && npm run type-check"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.2.0",
    "@types/node": "^20.0.0",
    "jest": "^29.0.0",
    "@types/jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "eslint": "^8.40.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "prettier": "^3.0.0"
  }
}
